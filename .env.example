# Supabase — projeto usado para armazenar os pedidos de diagnóstico do formulário de contato
# e os leads de download de materiais. Lido em services/supabase/server.ts.
# A URL não é secreta: SUPABASE_URL ou NEXT_PUBLIC_SUPABASE_URL funcionam (nessa ordem).
# SUPABASE_SERVICE_ROLE_KEY é secreta — nunca use o prefixo NEXT_PUBLIC_ nela.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile — proteção anti-bot invisível no formulário de download de materiais.
# Opcional: se não configurado, o formulário funciona normalmente sem o desafio do Turnstile
# (as demais camadas anti-bot — honeypot, tempo mínimo e rate limit — continuam ativas).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Microsoft Clarity — opcional. Se não configurado, o script não é carregado.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Meta Conversions API — chave usada para criptografar (AES-256-GCM) o
# Access Token do Meta Pixel antes de gravá-lo no banco. Gere uma vez com:
#   openssl rand -base64 32
# Sem essa variável, a tela de Configurar do Meta Ads não consegue salvar
# nem enviar eventos (falha de forma controlada, nunca grava o token em
# texto puro). Trocar essa chave invalida qualquer token já salvo.
META_TOKEN_ENCRYPTION_KEY=

# Segredo que autentica o cron de retry da fila de conversões
# (app/api/cron/meta-retry/route.ts). A Vercel envia esse valor automaticamente
# no header Authorization ao disparar crons — defina o mesmo valor aqui e nas
# variáveis de ambiente do projeto na Vercel.
CRON_SECRET=
